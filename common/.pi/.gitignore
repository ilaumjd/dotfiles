# Ignore all files and directories by default
**

# Whitelist this .gitignore file first
!.gitignore

# Whitelist agent directory and specific files
!agent/
!agent/keybindings.json
!agent/persona-config.json
!agent/mcp.json

# Whitelist subdirectories we want (without recursive **)
!agent/git/
!agent/themes/
!agent/personas/
!agent/extensions/

# Whitelist scripts directory and specific files
!scripts/
!scripts/generate-models.js
