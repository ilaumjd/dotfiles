#!/bin/bash

# Source unified color palette
source ~/.config/_vars/colors.sh

# ── Rosé Pine (borders-local override; leaves colors.sh untouched) ──
ROSE_OVERLAY=0xff26233a # overlay — dimmer inactive edge
ROSE_HL_MED=0xff403d52  # highlight med — same color as the sketchybar pill border

options=(
	style=round
	active_color="$ROSE_HL_MED"
	inactive_color="$ROSE_OVERLAY"
	width=2.0
	hidpi=off
	ax_focus=on
	blacklist="Simulator"
)

borders "${options[@]}"
