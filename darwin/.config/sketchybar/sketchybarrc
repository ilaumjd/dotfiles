#!/bin/bash

PLUGIN_DIR="$CONFIG_DIR/plugins"

# Source colors and hardware config
source ~/.config/_vars/colors.sh
source ~/.config/_vars/hardware.sh

# ── Rosé Pine theme (sketchybar-local override; leaves colors.sh/borders untouched) ──
ROSE_BASE=0xff191724    # base background
ROSE_SURFACE=0xff1f1d2e # surface
ROSE_OVERLAY=0xff26233a # overlay
ROSE_MUTED=0xff6e6a86   # muted
ROSE_SUBTLE=0xff908caa  # subtle
ROSE_TEXT=0xffe0def4    # text
ROSE_TEXT_SOFT=0xffbdb9cf # text, dimmed to match the ghostty/tmux foreground
ROSE_LOVE=0xffeb6f92    # love (pink/red)
ROSE_GOLD=0xfff6c177    # gold
ROSE_ROSE=0xffebbcba    # rose
ROSE_PINE=0xff31748f    # pine (teal)
ROSE_FOAM=0xff9ccfd8    # foam (cyan)
ROSE_IRIS=0xffc4a7e7    # iris (lavender)
ROSE_HL_MED=0xff403d52  # highlight med (subtle edges)

# Override the semantic colors the bar items consume (swap ACCENT to taste:
# ROSE_IRIS / ROSE_ROSE / ROSE_FOAM / ROSE_GOLD / ROSE_LOVE / ROSE_PINE)
ACCENT_PRIMARY=$ROSE_IRIS # icon accent + active workspace (was yellow)
TEXT_PRIMARY=$ROSE_TEXT_SOFT # active labels (softened to match terminal)
TEXT_INACTIVE=$ROSE_MUTED # inactive workspace icons

# Floating pill colors (local to sketchybar)
BAR_COLOR=0xcc191724     # translucent Rosé Pine base → glassy pills (wallpaper bleeds through)
BAR_BORDER=$ROSE_HL_MED  # subtle Rosé Pine edge (kept opaque for a crisp glass rim)

##### Bar Appearance #####
# The bar itself is transparent. The visible glass is drawn on the left/right
# brackets below, so the two groups read as separate floating pills with the
# notch sitting in clean empty space between them.
sketchybar --bar position=top \
  color=0x00000000 \
  position=top \
  height="$BAR_HEIGHT" \
  margin="$BAR_MARGIN" \
  y_offset="$BAR_Y_OFFSET" \
  border_width=0 \
  blur_radius=0 \
  padding_left=16 \
  padding_right=16 \
  notch_width=200 \
  notch_offset=0 \
  display=all \
  hidden=off \
  topmost=window \
  sticky=on \
  font_smoothing=off \
  shadow=off

##### Changing Defaults #####
default=(
  padding_left=1
  padding_right=1
  icon.align=center
  icon.font.family="FiraCode Nerd Font"
  icon.font.style=SemiBold
  icon.font.size="$ICON_FONT_SIZE"
  icon.color="$ACCENT_PRIMARY"
  label.align=center
  label.font.family="SF Pro Text"
  label.font.style=SemiBold
  label.font.size="$LABEL_FONT_SIZE"
  label.color="$TEXT_PRIMARY"
  label.padding_left=6
  label.padding_right=6
  background.drawing=off
)
sketchybar --default "${default[@]}"

##### Adding Items #####
ITEM_DIR="$CONFIG_DIR/items"

# Invisible spacer used to create gaps between separate pills
gap=(
  icon.drawing=off
  label.drawing=off
  background.drawing=off
  padding_left=3
  padding_right=3
)

source "$ITEM_DIR/workspaces.sh"
sketchybar --add item left_gap left --set left_gap "${gap[@]}"
source "$ITEM_DIR/app.sh"

source "$ITEM_DIR/clock.sh"
sketchybar --add item right_gap right --set right_gap "${gap[@]}"
source "$ITEM_DIR/battery.sh"
source "$ITEM_DIR/volume.sh"
source "$ITEM_DIR/layout.sh"
source "$ITEM_DIR/tailscale.sh"

##### Grouping items into separate floating pills #####
pill=(
  background.drawing=on
  background.color="$BAR_COLOR"
  background.corner_radius="$BAR_CORNER_RADIUS"
  background.height="$BAR_HEIGHT"
  background.border_width=1
  background.border_color="$BAR_BORDER"
)

sketchybar --add bracket workspaces_pill workspace.1 workspace.2 workspace.3 workspace.4 workspace.5 workspace.6 \
  --set workspaces_pill "${pill[@]}"
sketchybar --add bracket app_pill app --set app_pill "${pill[@]}"
sketchybar --add bracket status_pill tailscale layout volume battery --set status_pill "${pill[@]}"
sketchybar --add bracket clock_pill clock --set clock_pill "${pill[@]}"

# Inner padding so icons/labels don't touch the pill edges
sketchybar --set workspace.1 icon.padding_left=10 \
  --set workspace.6 icon.padding_right=10 \
  --set app label.padding_right=12 \
  --set tailscale icon.padding_left=12 \
  --set battery label.padding_right=12 \
  --set clock icon.padding_left=12 \
  --set clock label.padding_right=12

##### Force all scripts to run the first time #####
sketchybar --update
